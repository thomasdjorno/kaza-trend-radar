# Mot de passe unique pour accéder à l'outil (protection middleware).
APP_PASSWORD=change-me

# Clé API Anthropic (scoring des tendances, analyse détaillée, prompts vidéo).
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Clé API YouTube Data v3 (YouTube Trending FR).
# https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# App Reddit (type "script", lecture seule) pour l'API OAuth officielle —
# le endpoint public www.reddit.com/*.json est bloqué depuis la plupart des IP serveur.
# Créer sur https://www.reddit.com/prefs/apps → "create app" → type "script".
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Optionnel : port d'écoute en production (utilisé par pm2 / next start).
PORT=3000

# Uniquement pour un déploiement Netlify (cache/historique via Netlify Blobs).
# NETLIFY_SITE_ID : Site configuration → General → Project details → Project ID.
# NETLIFY_BLOBS_TOKEN : un Personal Access Token créé sur app.netlify.com/user/applications.
# Laisser vide en local / sur VPS — le cache fichier est utilisé automatiquement.
NETLIFY_SITE_ID=
NETLIFY_BLOBS_TOKEN=
